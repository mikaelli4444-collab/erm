# DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# JWT
SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# EMAIL
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_EMAIL=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER_HOST=smtp.gmail.com
MAIL_FROM_NAME=Your App Name
USE_CREDENTIALS=True
USE_TLS=True
USE_SSL=False
VERIFICATION_TOKEN_EXPIRE_MINUTES=60

# STORAGE (R2 / S3)
STORAGE_BUCKET_NAME=your_bucket
STORAGE_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_MEDIA_BASE_URL=https://your-public-url.r2.dev

#AbacatePay
ABACATE_PAY_KEY=...
ABACATE_PAY_WEBHOOK_SECRET=...
ABACATE_BASE_URL=https://api.abacatepay.com/v2


#Configuration for URL
URL_EXPIRATION_MINUTES=...
BASE_URL=https://your-app-url.com